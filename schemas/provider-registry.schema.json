{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://comptext.local/schemas/provider-registry.schema.json",
  "title": "COMPTEXT Provider Registry",
  "type": "object",
  "required": ["providers"],
  "properties": {
    "providers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "display_name", "state"],
        "properties": {
          "id": {"type": "string"},
          "display_name": {"type": "string"},
          "state": {
            "type": "string",
            "enum": ["not_configured", "disabled", "experimental"]
          }
        }
      }
    }
  }
}
