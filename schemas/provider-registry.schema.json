{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://comptext.local/schemas/provider-registry.schema.json",
  "title": "COMPTEXT Provider Registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "providers"],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "providers": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "state"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "state": {
            "type": "string",
            "enum": ["not_configured", "disabled", "experimental"]
          }
        }
      }
    }
  }
}
