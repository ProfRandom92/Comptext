{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://comptext.local/schemas/plugin.schema.json",
  "title": "COMPTEXT Plugin Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name",
    "version",
    "status",
    "purpose",
    "capabilities",
    "skills",
    "hooks",
    "schemas",
    "checks",
    "safety_rules"
  ],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "const": "experimental"
    },
    "purpose": {
      "type": "string",
      "minLength": 1
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^skills/.+/SKILL\\.md$"
      }
    },
    "hooks": {
      "type": "array"
    },
    "schemas": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "safety_rules": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
