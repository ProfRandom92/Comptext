{
  "name": "comptext-core",
  "version": "0.1.0",
  "status": "experimental",
  "purpose": "Local dry-run core guidance for CompText repository bootstrap, CLI, schema validation, and runtime samples.",
  "capabilities": [
    "local_bootstrap_guidance",
    "dry_run_cli_guidance",
    "schema_validation_guidance",
    "runtime_sample_guidance"
  ],
  "skills": [
    "skills/comptext-bootstrap/SKILL.md",
    "skills/comptext-dry-run-cli/SKILL.md",
    "skills/comptext-schema-validation/SKILL.md",
    "skills/comptext-runtime/SKILL.md"
  ],
  "hooks": [],
  "schemas": [
    "schemas/skill.schema.json",
    "schemas/plugin.schema.json"
  ],
  "checks": [
    "python -m compileall modules tests",
    "$env:PYTHONPATH=\".\"; python -m pytest -q tests"
  ],
  "safety_rules": [
    "local_dry_run_only",
    "no_provider_calls",
    "no_gateway_start",
    "no_mcp_start",
    "no_secrets"
  ]
}
